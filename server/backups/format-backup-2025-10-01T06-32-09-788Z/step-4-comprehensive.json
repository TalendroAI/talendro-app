{
  "id": "step-4-comprehensive",
  "title": "Professional Information",
  "route": "/app/onboarding/step-4",
  "nextRoute": "/app/onboarding/step-5",
  "sections": [
    {
      "title": "General Employment Questions",
      "fields": [
        { "key": "desiredSalary", "label": "What is your desired base annual salary?", "type": "text", "required": true, "validation": { "pattern": "^\\$?[0-9]{1,3}(,?[0-9]{3})*(\\.[0-9]{2})?$", "message": "Please enter a valid salary amount (e.g., $50,000 or 50000)" } },
        { "key": "availability", "label": "After accepting an offer, when will you be available to start work?", "type": "select", "required": true, "options": [
          {"value":"","label":"Select"},
          {"value":"immediately","label":"Immediately"},
          {"value":"one_week","label":"One week"},
          {"value":"two_weeks","label":"Two weeks"},
          {"value":"three_weeks","label":"Three weeks"},
          {"value":"four_weeks","label":"Four weeks"}
        ] },
        { "key": "workArrangement", "label": "What is your preferred work arrangement?", "type": "multiselect", "required": true, "options": [
          {"value":"onsite","label":"Onsite"},
          {"value":"remote","label":"Remote"},
          {"value":"hybrid","label":"Hybrid"}
        ] },
        { "key": "willingToRelocate", "label": "Are you willing to relocate?", "type": "select", "required": true, "options": [
          {"value":"","label":"Select"},
          {"value":"yes","label":"Yes"},
          {"value":"no","label":"No"}
        ] },
        { "key": "restrictions", "label": "Do you have any restrictions that would prevent you from performing the essential functions of this role?", "type": "select", "required": true, "options": [
          {"value":"","label":"Select"},
          {"value":"yes","label":"Yes"},
          {"value":"no","label":"No"}
        ] },
        { "key": "travelPercentage", "label": "What percentage of time are you willing to travel for work?", "type": "select", "required": true, "options": [
          {"value":"","label":"Select"},
          {"value":"0","label":"0%"},
          {"value":"25","label":"25%"},
          {"value":"50","label":"50%"},
          {"value":"75","label":"75%"},
          {"value":"100","label":"100%"}
        ] },
        { "key": "restrictionsExplanation", "label": "If yes, please explain:", "type": "textarea", "required": false }
      ]
    },
    {
      "title": "Legal and Compliance Questions",
      "fields": [
        { "key": "authorizedToWork", "label": "Are you currently legally authorized to work in the USA without visa sponsorship?", "type": "select", "required": true, "options": [
          {"value":"","label":"Select"},
          {"value":"yes","label":"Yes"},
          {"value":"no","label":"No"}
        ] },
        { "key": "nonCompeteAgreement", "label": "Are you currently bound by a non-compete or non-solicitation agreement from a previous employer?", "type": "select", "required": true, "options": [
          {"value":"","label":"Select"},
          {"value":"yes","label":"Yes"},
          {"value":"no","label":"No"}
        ] },
        { "key": "futureVisaSponsorship", "label": "Will you require visa sponsorship in the future to continue working in the USA?", "type": "select", "required": true, "options": [
          {"value":"","label":"Select"},
          {"value":"yes","label":"Yes"},
          {"value":"no","label":"No"}
        ] },
        { "key": "criminalHistory", "label": "Have you ever been convicted of a felony or misdemeanor, other than minor traffic citations?", "type": "select", "required": true, "options": [
          {"value":"","label":"Select"},
          {"value":"yes","label":"Yes"},
          {"value":"no","label":"No"}
        ] },
        { "key": "backgroundCheck", "label": "Are you willing to undergo a background check or drug screening upon offer acceptance?", "type": "select", "required": true, "options": [
          {"value":"","label":"Select"},
          {"value":"yes","label":"Yes"},
          {"value":"no","label":"No"}
        ] },
        { "key": "criminalHistoryExplanation", "label": "If yes, please explain:", "type": "textarea", "required": false }
      ]
    }
  ],
  "collections": [
    {
      "key": "employmentHistory",
      "title": "Employment History (10 Years required)",
      "addLabel": "Add Another Employer",
      "minItems": 1,
      "fields": [
        { "key": "companyName", "label": "Company Name", "type": "text", "required": true },
        { "key": "employmentStartDate", "label": "Employment Start Date", "type": "date", "required": true },
        { "key": "jobTitle", "label": "Job Title", "type": "text", "required": true },
        { "key": "employmentEndDate", "label": "Employment End Date", "type": "employmentEndDate", "required": false },
        { "key": "companyCity", "label": "Company City", "type": "text", "required": true },
        { "key": "companyCountry", "label": "Company Country", "type": "select", "required": true, "options": [
          {"value":"","label":"Select"},
          {"value":"US","label":"United States"},{"value":"CA","label":"Canada"},{"value":"GB","label":"United Kingdom"}
        ] },
        { "key": "companyState", "label": "Company State", "type": "select", "required": true, "options": [
          {"value":"","label":"Select"},
          {"value":"AL","label":"Alabama"},{"value":"AK","label":"Alaska"},{"value":"AZ","label":"Arizona"},{"value":"AR","label":"Arkansas"},
          {"value":"CA","label":"California"},{"value":"CO","label":"Colorado"},{"value":"CT","label":"Connecticut"},{"value":"DE","label":"Delaware"},
          {"value":"FL","label":"Florida"},{"value":"GA","label":"Georgia"},{"value":"HI","label":"Hawaii"},{"value":"ID","label":"Idaho"},
          {"value":"IL","label":"Illinois"},{"value":"IN","label":"Indiana"},{"value":"IA","label":"Iowa"},{"value":"KS","label":"Kansas"},
          {"value":"KY","label":"Kentucky"},{"value":"LA","label":"Louisiana"},{"value":"ME","label":"Maine"},{"value":"MD","label":"Maryland"},
          {"value":"MA","label":"Massachusetts"},{"value":"MI","label":"Michigan"},{"value":"MN","label":"Minnesota"},{"value":"MS","label":"Mississippi"},
          {"value":"MO","label":"Missouri"},{"value":"MT","label":"Montana"},{"value":"NE","label":"Nebraska"},{"value":"NV","label":"Nevada"},
          {"value":"NH","label":"New Hampshire"},{"value":"NJ","label":"New Jersey"},{"value":"NM","label":"New Mexico"},{"value":"NY","label":"New York"},
          {"value":"NC","label":"North Carolina"},{"value":"ND","label":"North Dakota"},{"value":"OH","label":"Ohio"},{"value":"OK","label":"Oklahoma"},
          {"value":"OR","label":"Oregon"},{"value":"PA","label":"Pennsylvania"},{"value":"RI","label":"Rhode Island"},{"value":"SC","label":"South Carolina"},
          {"value":"SD","label":"South Dakota"},{"value":"TN","label":"Tennessee"},{"value":"TX","label":"Texas"},{"value":"UT","label":"Utah"},
          {"value":"VT","label":"Vermont"},{"value":"VA","label":"Virginia"},{"value":"WA","label":"Washington"},{"value":"WV","label":"West Virginia"},
          {"value":"WI","label":"Wisconsin"},{"value":"WY","label":"Wyoming"}
        ] },
        { "key": "reasonForLeaving", "label": "Reason for Leaving", "type": "text", "required": true },
        { "key": "responsibilities", "label": "Responsibilities/Achievements", "type": "textarea", "required": true }
      ]
    }
  ]
}